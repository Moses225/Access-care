rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ================================================================
    // HELPER FUNCTIONS
    // ================================================================

    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }
    function isFullAccount() {
      return isAuthenticated() &&
             request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    function isProviderOwner(providerId) {
      return isAuthenticated()
          && request.auth.token.provider == true
          && request.auth.token.providerId == providerId;
    }
    function isVerifiedProvider() {
      return isAuthenticated()
          && request.auth.token.provider == true
          && exists(/databases/$(database)/documents/providerUsers/$(request.auth.uid));
    }
    function isBookingPatient() {
      return isAuthenticated()
          && resource.data.userId == request.auth.uid;
    }
    function isBookingProvider() {
      return isAuthenticated()
          && request.auth.token.providerId == resource.data.providerId;
    }

    function validString(field, maxLen) {
      return field is string && field.size() > 0 && field.size() <= maxLen;
    }

    function validOptionalString(field, maxLen) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == null ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() <= maxLen);
    }

    function noScript(field) {
      let v = request.resource.data[field];
      // Block script/iframe/object injection and common XSS vectors.
      // Defense-in-depth: React already HTML-escapes rendered output; these
      // rules prevent stored payloads from reaching the database at all.
      return !(v.matches('.*<script.*'))
          && !(v.matches('.*javascript:.*'))
          && !(v.matches('.*vbscript:.*'))
          && !(v.matches('.*<iframe.*'))
          && !(v.matches('.*<img.*'))
          && !(v.matches('.*<svg.*'))
          && !(v.matches('.*<object.*'))
          && !(v.matches('.*<embed.*'))
          && !(v.matches('.*<form.*'))
          && !(v.matches('.*on[a-zA-Z]+\\s*=.*'))  // any on* event handler
          && !(v.matches('.*data:text/html.*'))
          && !(v.matches('.*data:application.*'))
          && !(v.matches('.*%3[cC].*'))             // URL-encoded <
          && !(v.matches('.*\\\\u003[cC].*'))        // Unicode-escaped <
          && !(v.matches('.*expression\\s*\\(.*'));  // IE CSS expression()
    }

    // ================================================================
    // PROVIDERS
    // ================================================================
    // isProviderSafeUpdate — blocks providers from self-upgrading plan/billing fields
    // H-2: 'hsaEligible' and 'verified' are admin-only — providers cannot self-certify
    function isProviderSafeUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'plan', 'foundingExpiresAt', 'stripeCustomerId',
        'stripePaymentMethodId', 'stripeSubscriptionId',
        'manualBilling', 'isFoundingProvider', 'planActivatedAt',
        'providerNumber', 'commissionRate', 'billable',
        'hsaEligible', 'verified'
      ]);
    }

    // ================================================================
    // RECOVERY FACILITY HELPERS
    // ================================================================
    // isFacilityManager — verifies the caller owns this facility via custom claim
    // facilityId is stamped into the token by Admin SDK (setRecoveryFacilityRole.js)
    // so it cannot be self-edited by the operator.
    function isFacilityManager(facilityId) {
      return isAuthenticated()
          && request.auth.token.provider == true
          && request.auth.token.facilityId == facilityId;
    }

    // isRecoverySafeUpdate — operators can update operational fields but NEVER
    // billing or system fields. Only Admin SDK (Cloud Functions) can touch these.
    function isRecoverySafeUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'listingStatus', 'listingPlan', 'freeTrialStartedAt', 'warningEmailSent',
        'managedByUid', 'active', 'verified', 'foundingComp', 'foundingCompNote'
      ])
      // Script guards on operator-editable free-text fields (defense-in-depth;
      // all render paths also escape, but block stored payloads at the source)
      && (!('description' in request.resource.data)       || noScript('description'))
      && (!('houseRules' in request.resource.data)        || noScript('houseRules'))
      && (!('intakeNotes' in request.resource.data)       || noScript('intakeNotes'))
      && (!('facilityName' in request.resource.data)      || noScript('facilityName'))
      && (!('ownerName' in request.resource.data)         || noScript('ownerName'))
      && (!('curfew' in request.resource.data)            || noScript('curfew'))
      && (!('familyHousingNote' in request.resource.data) || noScript('familyHousingNote'));
    }

    // isProviderUsersSafeUpdate — blocks recovery facility operators from
    // self-granting paid tiers, changing roles, or hijacking another facility.
    function isProviderUsersSafeUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny([
        'role', 'listingPlan', 'listingStatus', 'facilityId',
        'freeTrialStartedAt', 'warningEmailSent', 'providerId',
        'plan', 'foundingExpiresAt', 'stripeCustomerId',
        'stripePaymentMethodId', 'stripeSubscriptionId',
        'manualBilling', 'isFoundingProvider', 'planActivatedAt',
        'providerNumber', 'commissionRate', 'billable'
      ]);
    }

    match /providers/{providerId} {
      // Provider profiles are public discovery content — readable by anyone
      // (authenticated or not). This enables moravacare.com website search for
      // unauthenticated visitors. Sensitive financial fields (stripeCustomerId,
      // stripePaymentMethodId, commissionRate, etc.) are in the private billing
      // subcollection below and remain restricted to owner + admin only.
      allow read: if true;
      allow create: if isAdmin();
      allow delete: if isAdmin();
      // M-3: noScript guards on free-text provider fields that render in the
      // patient app and dashboard. Providers cannot inject scripts via bio,
      // address, or DPC description fields.
      allow update: if isAdmin()
        || (isProviderOwner(providerId)
            && isProviderSafeUpdate()
            && (!('bio' in request.resource.data)          || validOptionalString('bio', 2000)          && noScript('bio'))
            && (!('address' in request.resource.data)      || validOptionalString('address', 300)        && noScript('address'))
            && (!('dpcDescription' in request.resource.data) || validOptionalString('dpcDescription', 1000) && noScript('dpcDescription'))
            && (!('name' in request.resource.data)         || validString(request.resource.data.name, 200) && noScript('name'))
            && (!('practiceName' in request.resource.data) || validOptionalString('practiceName', 200)   && noScript('practiceName')));

      // ── Billing subcollection ─────────────────────────────────────────────
      // Stores sensitive financial fields: stripeCustomerId, stripePaymentMethodId,
      // stripeSubscriptionId, manualBilling, commissionRate, billable,
      // planActivatedAt, providerNumber, billingSetupAt.
      //
      // Only the provider who owns this account and admins can read it.
      // Writes come exclusively from Cloud Functions via the Admin SDK —
      // no client write path exists (allow write: if false).
      //
      // NOTE: hsaEligible intentionally stays on the parent providers doc because
      // it is a patient-visible badge rendered in the patient app's provider list.
      match /billing/{billingId} {
        allow read: if isProviderOwner(providerId) || isAdmin();
        allow write: if false; // Admin SDK only — stripeWebhook, createSetupIntent, requestManualBilling
      }
    }

    // ================================================================
    // USERS
    // ================================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      // Users can edit their own doc EXCEPT privileged fields that only
      // the backend can grant (vouchers, admin flags, internal metadata).
      allow write: if isOwner(userId)
                  && (!('firstName' in request.resource.data) || noScript('firstName'))
                  && (!('lastName' in request.resource.data) || noScript('lastName'))
                  // Prevent users from self-granting vouchers or privileges
                  && !request.resource.data.diff(resource.data).affectedKeys()
                      .hasAny(['voucherEligible', 'voucherUsed', 'isAdmin',
                               'adminOverride', 'creditBalance']);

      match /dependents/{dependentId} {
        allow read:   if isOwner(userId) && isFullAccount();
        allow create: if isOwner(userId) && isFullAccount()
                   && validString(request.resource.data.firstName, 100)
                   && validString(request.resource.data.lastName, 100)
                   && noScript('firstName')
                   && noScript('lastName');
        allow update: if isOwner(userId) && isFullAccount()
                   && validString(request.resource.data.firstName, 100)
                   && validString(request.resource.data.lastName, 100);
        allow delete: if isOwner(userId) && isFullAccount();
      }
    }

    // ================================================================
    // BOOKINGS
    // ================================================================
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() &&
                     (isBookingPatient() || isBookingProvider() || isAdmin());

      // ── providerNotes subcollection ───────────────────────────────────────
      // HIPAA design: provider-only clinical notes stored separately from the
      // booking document so patients can NEVER access them, even indirectly.
      // Patients have no rule granting them access here — the catch-all denies.
      // Notes are write-once from the dashboard; providers can delete their own.
      match /providerNotes/{noteId} {
        // read/delete: use get() on parent booking — isBookingProvider() checks
        // resource.data.providerId which is unreliable for LIST/QUERY operations
        // (Firestore evaluates rules against a synthetic resource for queries).
        // Same get() pattern as allow create below.
        allow read: if isAuthenticated()
                    && (isAdmin()
                        || (isVerifiedProvider()
                            && get(/databases/$(database)/documents/bookings/$(bookingId)).data.providerId
                               == request.auth.token.providerId));
        allow delete: if isAdmin()
                      || (isVerifiedProvider()
                          && get(/databases/$(database)/documents/bookings/$(bookingId)).data.providerId
                             == request.auth.token.providerId);

        // create: note doesn't exist yet — resource is null, so isBookingProvider()
        // (which checks resource.data.providerId) always fails on create.
        // Instead, look up the PARENT booking to confirm the provider owns it.
        allow create: if isVerifiedProvider()
                      && request.resource.data.providerId == request.auth.token.providerId
                      && get(/databases/$(database)/documents/bookings/$(bookingId)).data.providerId
                         == request.auth.token.providerId
                      && request.resource.data.text is string
                      && request.resource.data.text.size() > 0
                      && request.resource.data.text.size() <= 2000;

        allow update: if false; // notes are immutable — delete and re-create
      }

      allow create: if isFullAccount()
                 && request.resource.data.userId == request.auth.uid
                 && request.resource.data.status == 'pending'
                 && validString(request.resource.data.patientName, 150)
                 && validString(request.resource.data.date, 20)
                 && validString(request.resource.data.time, 10)
                 && validString(request.resource.data.providerId, 200)
                 && noScript('patientName')
                 && validOptionalString('notes', 1000)
                 && validOptionalString('reasonForVisit', 500);

      allow update: if (isAdmin()
                 || (isBookingProvider()
                     && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['status','confirmedAt','confirmedBy','declineReason',
                                  'declineNote','completedAt','completedBy','billable',
                                  'invoiced','invoicedAt','stripePaymentIntentId',
                                  'noShowAt','noShowBy','proposedDate','proposedTime',
                                  'rescheduledAt','rescheduledBy','updatedAt',
                                  'preRescheduleStatus','cancelledAt','cancelledBy',
                                  'providerMarkedEnrolled','providerEnrolledAt']))
                 // DPC enrollment — patient confirms they enrolled as a member.
                 // Can only flip the patientConfirmedEnrolled flag, nothing else.
                 || (isBookingPatient()
                     && isFullAccount()
                     && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['patientConfirmedEnrolled','patientEnrolledAt']))
                 // Patient cancellation — cannot change date, time, provider, or userId
                 || (isBookingPatient()
                     && isFullAccount()
                     && request.resource.data.status == 'cancelled'
                     && request.resource.data.userId == resource.data.userId
                     && request.resource.data.providerId == resource.data.providerId
                     && request.resource.data.date == resource.data.date
                     && request.resource.data.time == resource.data.time)
                 // Patient responds to a provider-proposed reschedule:
                 //   Accept  → status becomes 'confirmed', date/time updated to proposed values
                 //   Decline → status reverts to preRescheduleStatus ('confirmed' or 'pending'),
                 //             original date/time preserved, rescheduleDeclinedAt stamped
                 // Patient cannot change providerId or userId in either case.
                 || (isBookingPatient()
                     && isFullAccount()
                     && resource.data.status == 'reschedule_pending'
                     && (request.resource.data.status == 'confirmed'
                         || request.resource.data.status == 'pending')
                     && request.resource.data.userId == resource.data.userId
                     && request.resource.data.providerId == resource.data.providerId
                     && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['status','date','time','proposedDate','proposedTime',
                                  'rescheduleAcceptedAt','rescheduleDeclinedAt'])));
      allow delete: if isAdmin();
    }

    // ================================================================
    // AVAILABILITY
    // ================================================================
    match /availability/{providerId} {
      allow read: if isAuthenticated();
      match /slots/{date} {
        allow read: if isAuthenticated();
        allow create, update: if isAdmin() || isProviderOwner(providerId);
        allow delete: if isAdmin() || isProviderOwner(providerId);
      }
    }

    // ================================================================
    // QUESTIONS
    // ================================================================
    match /questions/{questionId} {
      allow read: if isOwner(resource.data.userId) || isAdmin();
      allow create: if isFullAccount()
                 && request.resource.data.userId == request.auth.uid
                 && validString(request.resource.data.content, 2000)
                 && noScript('content');
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ================================================================
    // INSURANCE
    // ================================================================
    match /insurance/{userId} {
      allow read:  if isOwner(userId);
      // noScript on free-text fields that render in the patient app.
      // policy/provider fields intentionally not validated beyond size caps
      // because insurance IDs contain special chars (hyphens, digits, etc.).
      allow write: if isOwner(userId)
                && isFullAccount()
                && validOptionalString('provider', 200)
                && validOptionalString('medical', 200)
                && validOptionalString('policy', 100)
                && validOptionalString('dental', 200)
                && validOptionalString('vision', 200)
                && validOptionalString('paymentOption', 50)
                && validOptionalString('insuranceType', 20)
                && (!('provider' in request.resource.data) || request.resource.data.provider == null || noScript('provider'))
                && (!('medical' in request.resource.data)  || request.resource.data.medical == null  || noScript('medical'))
                && (!('dental' in request.resource.data)   || request.resource.data.dental == null   || noScript('dental'))
                && (!('vision' in request.resource.data)   || request.resource.data.vision == null   || noScript('vision'));
    }

    // ================================================================
    // NOTIFICATIONS
    // ================================================================
    match /notifications/{userId} {
      allow read:  if isOwner(userId);
      allow write: if isOwner(userId)
                  && (!('firstName' in request.resource.data) || noScript('firstName'))
                  && (!('lastName' in request.resource.data) || noScript('lastName'));
    }

    // ================================================================
    // PRIVACY SETTINGS
    // ================================================================
    match /privacy/{userId} {
      allow read:  if isOwner(userId);
      allow write: if isOwner(userId)
                  && (!('firstName' in request.resource.data) || noScript('firstName'))
                  && (!('lastName' in request.resource.data) || noScript('lastName'));
    }

    // ================================================================
    // PAYMENT METHODS
    // ================================================================
    match /paymentMethods/{docId} {
      allow read, delete: if isAuthenticated() &&
                             resource.data.userId == request.auth.uid;
      allow create: if isFullAccount()
                 && request.resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ================================================================
    // SUPPORT REQUESTS
    // ================================================================
    match /supportRequests/{docId} {
      allow read: if isAuthenticated() &&
                     (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isFullAccount()
                 && request.resource.data.userId == request.auth.uid
                 && validString(request.resource.data.message, 5000)
                 && noScript('message');
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ================================================================
    // SAVED PROVIDERS
    // ================================================================
    match /savedProviders/{userId} {
      allow read, write: if isOwner(userId) && isFullAccount();
    }

    // ================================================================
    // PROVIDER USERS (Dashboard accounts)
    // ================================================================
    match /providerUsers/{userId} {
      // Read: document owner only — isOwner already guarantees the caller is
      // authenticated and reading THEIR OWN document, so no other user can
      // access this.  We do NOT require provider: true here because that creates
      // a chicken-and-egg problem: a provider can't read their doc to discover
      // their providerId before their custom claims are stamped on the token.
      // The ensureProviderClaims Cloud Function is called from AuthContext when
      // claims are absent, setting them before any sensitive Firestore access.
      allow read:  if isOwner(userId);
      // Operators may update only non-system fields.
      // Billing (listingPlan, listingStatus), role, facilityId, and plan fields
      // are admin-only — users cannot self-grant tiers or change roles.
      allow write: if isOwner(userId)
                  && isVerifiedProvider()
                  && isProviderUsersSafeUpdate();
      allow write: if isAdmin();
    }

    // ================================================================
    // AUDIT LOG
    // ================================================================
    match /auditLog/{entryId} {
      allow create: if isFullAccount()
                 // Caller can only log actions under their own UID — prevents
                 // one user from forging audit entries attributed to another user
                 && request.resource.data.actorUid == request.auth.uid
                 && validOptionalString('action', 100)
                 && validOptionalString('targetId', 200)
                 && validOptionalString('actorUid', 128)
                 && validOptionalString('actorType', 20)
                 && validOptionalString('targetCollection', 100);
      allow read:   if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ================================================================
    // ANALYTICS EVENTS
    // ================================================================
    match /analytics_events/{docId} {
      allow create: if isAuthenticated()
                 && validOptionalString('eventName', 100)
                 && validOptionalString('screen', 100);
      allow read:   if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ================================================================
    // PROVIDER APPLICATIONS
    // ================================================================
    match /providerApplications/{docId} {
      allow create: if validString(request.resource.data.name, 200)
                 && validString(request.resource.data.email, 200)
                 && noScript('name')
                 && noScript('email')
                 && validOptionalString('phone', 20)
                 && validOptionalString('specialty', 100)
                 && (!('practiceType' in request.resource.data) || validString(request.resource.data.practiceType, 30))
                 && (!('dpcDescription' in request.resource.data) || validOptionalString(request.resource.data.dpcDescription, 500))
                 && (!('telehealthAvailable' in request.resource.data) || request.resource.data.telehealthAvailable is bool)
                 && (!('telehealthOnly' in request.resource.data) || request.resource.data.telehealthOnly is bool)
                 && (!('acceptsSelfPay' in request.resource.data) || request.resource.data.acceptsSelfPay is bool)
                 && (!('acceptsMedicaid' in request.resource.data) || request.resource.data.acceptsMedicaid is bool)
                 && (!('fqhc' in request.resource.data) || request.resource.data.fqhc is bool)
                 && (!('tribal' in request.resource.data) || request.resource.data.tribal is bool)
                 && (!('slidingScale' in request.resource.data) || request.resource.data.slidingScale is bool)
                 && validOptionalString('message', 2000);
      allow read, update, delete: if isAdmin();
    }

    // ================================================================
    // INTAKE FORMS
    // ================================================================
    // INTAKE FORMS — patient health profiles
    // Uses setDoc with arrays, timestamps, and nested lifestyle object.
    // Validation focuses on required userId and size-capping text fields.
    match /intakeForms/{docId} {
      allow read: if isAuthenticated() &&
                  (request.auth.uid == resource.data.userId || isAdmin());
      allow create, update: if isFullAccount()
                && request.resource.data.userId == request.auth.uid
                && validOptionalString('bloodType',            10)
                && validOptionalString('heightFeet',            5)
                && validOptionalString('heightInches',          5)
                && validOptionalString('height',               20)
                && validOptionalString('weight',               20)
                && validOptionalString('primaryCareProvider', 200)
                && validOptionalString('pregnancyStatus',      50)
                // noScript on free-text PHI fields — injection prevention
                && (!('primaryCareProvider' in request.resource.data)
                    || request.resource.data.primaryCareProvider == null
                    || noScript('primaryCareProvider'))
                && (!('pregnancyStatus' in request.resource.data)
                    || request.resource.data.pregnancyStatus == null
                    || noScript('pregnancyStatus'));
      allow delete: if false;
    }
    // ================================================================
    // PLATFORM COUNTERS
    // ================================================================
    // providerCount — used server-side only (founding plan logic in Cloud Functions).
    //   Admin SDK writes; no client write path. Clients cannot manipulate the
    //   founding-provider threshold by inflating this counter.
    // totalSignups — incremented by the patient app on registration.
    //   Strictly +1 per authenticated write; cannot jump or decrease.
    match /platform/{docId} {
      allow read: if isAuthenticated();
      // Admin can always write (e.g. repair counters)
      allow write: if isAdmin();
      // Patient signup counter — authenticated users can increment by exactly 1
      // or create the doc with totalSignups == 1.  providerCount is immutable
      // from the client; it is ONLY written by Admin SDK (onProviderUserCreated).
      allow create: if isFullAccount()
                 && request.resource.data.totalSignups == 1
                 && !('providerCount' in request.resource.data);
      allow update: if isFullAccount()
                 && request.resource.data.totalSignups ==
                    resource.data.totalSignups + 1
                 // providerCount must not change on client writes
                 && (  !('providerCount' in request.resource.data)
                     || request.resource.data.providerCount == resource.data.providerCount);
      allow delete: if false;
    }

    // ================================================================
    // VISIT SUMMARIES
    // ================================================================
    // H-1: visitSummaries documents have document ID == bookingId, but they do NOT
    // have a top-level userId field — so isBookingPatient() (which checks
    // resource.data.userId) would always be false for patients.
    // Fix: look up the parent booking document to verify ownership.
    // isBookingProvider() still works because visitSummary docs carry providerId.
    match /visitSummaries/{bookingId} {
      allow read: if isAuthenticated() &&
                   (isAdmin()
                    || isBookingProvider()
                    || (isFullAccount()
                        && get(/databases/$(database)/documents/bookings/$(bookingId)).data.userId == request.auth.uid));
      allow create, update: if isVerifiedProvider() || isAdmin();
      allow delete: if false;
    }

    // ================================================================
    // WAITLIST
    // ================================================================
    match /waitlist/{docId} {
      allow create: if request.resource.data.email is string
                 && request.resource.data.email.size() > 0
                 && request.resource.data.email.size() <= 200
                 && request.resource.data.source is string;
      allow read, update, delete: if isAdmin();
    }

    // ================================================================
    // REP APPLICATIONS — public create, admin read/update only
    // Strict validation: locked status, no script injection,
    // rate limiting enforced client-side + field size caps
    // ================================================================
    match /repApplications/{docId} {
      allow create: if
        // Required fields present and valid
        validString(request.resource.data.name, 200)
        && validString(request.resource.data.email, 200)
        && noScript('name')
        && noScript('email')
        // Status must be 'new' on creation — cannot self-approve
        && request.resource.data.status == 'new'
        // Numeric fields must be zero on creation
        && request.resource.data.verifiedCount == 0
        && request.resource.data.pendingEarnings == 0
        // Optional field size caps
        && validOptionalString('phone', 20)
        && validOptionalString('city', 100)
        && validOptionalString('role', 100)
        && validOptionalString('hoursPerWeek', 50)
        && validOptionalString('paymentMethod', 50)
        && validOptionalString('paymentHandle', 100)
        && validOptionalString('heardFrom', 100)
        && validOptionalString('referredBy', 200)
        && validOptionalString('whyInterested', 1000)
        && validOptionalString('connections', 100)
        && validOptionalString('salesExp', 100)
        && validOptionalString('outreachMethods', 300)
        && validOptionalString('source', 100);

      // Only admin can read full application data
      allow read: if isAdmin();

      // Only admin can update (approve/reject, increment verifiedCount)
      allow update: if isAdmin();

      allow delete: if false;
    }

    // ================================================================
    // REP APP STATUS — minimal public status check (no sensitive data)
    // Written automatically when application is submitted.
    // Contains only: email, status, submittedAt — nothing sensitive.
    // ================================================================
    match /repAppStatus/{docId} {
      // Public create — written alongside repApplications on submit
      allow create: if
        validString(request.resource.data.email, 200)
        && request.resource.data.status == 'new'
        && noScript('email');

      // Read restricted to admin only — email is PII in healthcare context
      allow read: if isAdmin();

      // Only admin updates status (approved/rejected)
      allow update: if isAdmin();

      allow delete: if false;
    }

    // ================================================================
    // PROVIDER SUBMISSIONS — two write surfaces, same collection:
    //
    //   1. Web portal (moravacare.com/reps) — unauthenticated writes.
    //      Security gate is the OTP Cloud Function (verifyRepCode).
    //      Firestore enforces field shapes + locked status/commission.
    //
    //   2. Mobile app (/rep portal) — Firebase Auth + rep:true claim.
    //      The create rule below is auth-agnostic so both surfaces work;
    //      the mobile app's UI is already guarded by the claim check in
    //      _layout.tsx / rep/_layout.tsx before any write can happen.
    //
    // Reads: mobile-app reps read their own docs (rep claim + email
    //   match). Web portal status tab uses a Cloud Function query, not
    //   a direct Firestore read, so no unauthenticated read needed.
    // Admin can always read/update.
    // ================================================================
    match /providerSubmissions/{docId} {
      allow create: if
        // Required fields present and valid
        validString(request.resource.data.providerName, 200)
        && validString(request.resource.data.repEmail, 200)
        && noScript('providerName')
        && noScript('repEmail')
        // Status must be pending on creation — cannot self-approve
        && request.resource.data.status == 'pending_verification'
        // Commission fields must be false/null on creation
        && request.resource.data.commissionPaid == false
        // Optional field caps
        && validOptionalString('practiceName', 200)
        && validOptionalString('specialty', 100)
        && validOptionalString('city', 100)
        && validOptionalString('providerPhone', 20)
        && validOptionalString('providerEmail', 200)
        && validOptionalString('npi', 10)
        && validOptionalString('repName', 200)
        && validOptionalString('repPayment', 100)
        && validOptionalString('contactMethod', 100)
        && validOptionalString('interestLevel', 100)
        && validOptionalString('notes', 1000)
        && validOptionalString('telehealth', 50)
        && validOptionalString('acceptingNewPatients', 50)
        && validOptionalString('source', 100)
        && validOptionalString('claimedBy', 200);

      // Web portal reads go through getRepSubmissions Cloud Function (Admin SDK).
      // No rep Firebase Auth claim exists — the dead branch below is removed.
      allow read: if isAdmin();

      // Only admin can update status, commission, notes
      allow update: if isAdmin();

      allow delete: if false;
    }

    // ================================================================
    // ================================================================
    // RECOVERY HOUSING — May 2026
    // ================================================================
    match /recoveryHousing/{facilityId} {
      // Operator can always read their own facility (even if inactive/not-yet-live).
      // Everyone else can only read active listings.
      allow read: if resource.data.active == true
                  || isAdmin()
                  || isFacilityManager(facilityId);

      // Facility manager can update operational fields (availability, profile details)
      // but cannot touch billing/system fields — those are admin-only.
      allow update: if isFacilityManager(facilityId)
                    && isRecoverySafeUpdate();

      // Any authenticated patient can increment viewCount or inquiryCount only.
      // Used by the patient app when opening a facility or submitting an intake form.
      // Strictly limited to these two counter fields — no other fields can change.
      allow update: if isFullAccount()
                    && request.resource.data.diff(resource.data).affectedKeys()
                       .hasOnly(['viewCount', 'inquiryCount']);

      // Only admins can create facilities, do full updates (billing fields), or delete
      allow create: if isAdmin()
                    && validString(request.resource.data.facilityName, 200)
                    && request.resource.data.totalBeds is int
                    && validString(request.resource.data.phone, 20);
      allow update: if isAdmin();
      allow delete: if false;

      match /availability/{docId} {
        allow read: if true;
        // Facility manager can update availability subcollection too
        allow write: if isAdmin() || isFacilityManager(facilityId);
      }

      // Intake requests — written by authenticated patients (any signed-in Morava user),
      // readable by the facility manager who owns this facility OR by the patient who
      // submitted the request (needed for the duplicate-request rate-limit check).
      // Patients cannot read other patients' requests — the userId constraint enforces this.
      match /intakeRequests/{requestId} {
        allow read:   if isAdmin()
                      || isFacilityManager(facilityId)
                      || (isFullAccount() && resource.data.userId == request.auth.uid);

        // GAP 2 FIX: userId must match the caller (prevents attributing requests to other users)
        // GAP 3 FIX: noScript on name and message (defense-in-depth against injection)
        // GAP 4 FIX: phone length-capped; sobrietyDays must be a non-negative int when present
        allow create: if isFullAccount()
                      && request.resource.data.status == "pending"
                      // Enforce plan gate at DB level — free-tier facilities cannot
                      // receive in-app inquiries (UI-only gate was bypassable)
                      && get(/databases/$(database)/documents/recoveryHousing/$(facilityId)).data.listingPlan
                          in ['standard', 'growth', 'partner']
                      // Caller can only write their own userId (or omit it)
                      && (!(  'userId' in request.resource.data)
                          || request.resource.data.userId == request.auth.uid)
                      // patientName: required, max 150 chars, no script tags
                      && validString(request.resource.data.patientName, 150)
                      && noScript('patientName')
                      // phone: required, max 20 chars
                      && validString(request.resource.data.phone, 20)
                      // message: optional, max 500 chars, no script tags if present
                      && validOptionalString('message', 500)
                      && (!(  'message' in request.resource.data)
                          || request.resource.data.message == null
                          || noScript('message'))
                      // sobrietyDays: optional, must be a non-negative integer if present
                      && (!('sobrietyDays' in request.resource.data)
                          || request.resource.data.sobrietyDays == null
                          || (request.resource.data.sobrietyDays is int
                              && request.resource.data.sobrietyDays >= 0
                              && request.resource.data.sobrietyDays <= 36500));

        // Only the facility manager can update status (pending → contacted/admitted/declined)
        allow update: if (isAdmin() || isFacilityManager(facilityId))
                      && request.resource.data.diff(resource.data).affectedKeys()
                         .hasOnly(['status', 'notes', 'updatedAt']);
        allow delete: if isAdmin();
      }
    }

    // ================================================================
    // BILLING ALERTS — written server-side by stripeWebhook on payment failure
    // Admin-only read; no client write path (Admin SDK only).
    // ================================================================
    match /billingAlerts/{alertId} {
      allow read: if isAdmin();
      allow write: if false; // Admin SDK only
    }

    // ================================================================
    // SETUP-INTENT RATE LIMITS
    // ================================================================
    // Written server-side by createSetupIntent only (Admin SDK).
    // Prevents a compromised provider token from spamming the Stripe API.
    // Doc ID: "{providerId}_{YYYY-MM-DD}"
    match /setupIntentRateLimits/{docId} {
      allow read, write: if isAdmin();
      // All other access denied by catch-all
    }

    // ================================================================
    // SMS RATE LIMITS — M-2
    // ================================================================
    // Written server-side by sendSMSNotification Cloud Function only.
    // Doc ID format: "{providerId}_{YYYY-MM-DD}"
    // Providers cannot read or manipulate their own limit docs —
    // only the Cloud Function (admin SDK) writes here.
    match /smsRateLimits/{docId} {
      allow read, write: if isAdmin();
      // All other access (provider self-read, patient) — denied by catch-all
    }

    // ================================================================
    // REP OTP — admin-only (written/deleted by Cloud Functions only)
    // ================================================================
    match /repVerificationCodes/{docId} {
      allow read, write: if isAdmin();
    }
    match /repOtpRateLimit/{docId} {
      allow read, write: if isAdmin();
    }

    // ================================================================
    // REP SESSION TOKENS — written by verifyRepCode CF, read by getRepSubmissions CF.
    // Client-side access fully blocked — tokens are opaque and must only
    // be consumed server-side to prevent token enumeration attacks.
    // ================================================================
    match /repSessionTokens/{tokenId} {
      allow read, write: if false; // Admin SDK only
    }

    // ================================================================
    // PAYROLL RUNS — written by admin panel when marking rep commissions paid.
    // Admin-only read and write. No client can write without admin claim.
    // ================================================================
    match /payrollRuns/{runId} {
      allow read, write: if isAdmin();
    }

    // ================================================================
    // RECOVERY HOUSING SUBMISSIONS — public self-listing form.
    // Operators submit their facility from moravacare.com/list-recovery.
    // Public create (validated + script-guarded); admin reviews & promotes
    // to a real recoveryHousing listing. No public read — submissions are
    // not directory data until an admin approves them.
    // ================================================================
    match /recoveryHousingSubmissions/{docId} {
      allow read, update, delete: if isAdmin();
      allow create: if request.resource.data.status == "pending_review"
                    && validString(request.resource.data.organizationName, 200)
                    && noScript('organizationName')
                    && validString(request.resource.data.contactName, 150)
                    && noScript('contactName')
                    && validString(request.resource.data.phone, 30)
                    && validOptionalString('email', 200)
                    && validOptionalString('website', 300)
                    && validOptionalString('address', 300)
                    && (!('description' in request.resource.data) || (noScript('description') && request.resource.data.description.size() <= 1500))
                    && (!('admissionRequirements' in request.resource.data) || (noScript('admissionRequirements') && request.resource.data.admissionRequirements.size() <= 1500))
                    && (!('additionalInfo' in request.resource.data) || (noScript('additionalInfo') && request.resource.data.additionalInfo.size() <= 1500));
    }

    // ================================================================
    // CONFIG — platform-wide switches (e.g. billing.enabled master guard).
    // Admin-only write. Cloud Functions read via Admin SDK (bypass rules).
    // The billing master guard must never be flippable by a client.
    // ================================================================
    match /config/{docId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
    }

    // ================================================================
    // PHONE CHECK RATE LIMIT — written by checkPhoneAvailability function
    // Only Admin SDK writes here; clients cannot read or manipulate.
    // ================================================================
    match /phoneCheckRateLimit/{docId} {
      allow read, write: if isAdmin();
    }

    // ================================================================
    // INTAKE REQUESTS — collection group rule
    // Allows patients to query ALL their intake requests across facilities
    // via collectionGroup('intakeRequests').where('userId','==',uid).
    // Without this top-level rule, collection group queries are denied even
    // when the nested subcollection rule would allow the individual read.
    // Write/update/delete still governed by the nested recoveryHousing rule.
    // ================================================================
    match /{path=**}/intakeRequests/{requestId} {
      allow read: if isAdmin()
                  || (isFullAccount() && resource.data.userId == request.auth.uid);
    }

    // CATCH-ALL — deny everything not explicitly allowed
    // ================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
