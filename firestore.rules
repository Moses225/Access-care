rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }
    function isFullAccount() {
      return isAuthenticated() &&
             request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    function isProviderOwner(providerId) {
      return isAuthenticated()
          && request.auth.token.provider == true
          && request.auth.token.providerId == providerId;
    }
    function isVerifiedProvider() {
      return isAuthenticated()
          && request.auth.token.provider == true
          && exists(/databases/$(database)/documents/providerUsers/$(request.auth.uid));
    }
    function isBookingPatient() {
      return isAuthenticated()
          && resource.data.userId == request.auth.uid;
    }
    function isBookingProvider() {
      return isAuthenticated()
          && request.auth.token.providerId == resource.data.providerId;
    }

    match /providers/{providerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isProviderOwner(providerId);
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);
      match /dependents/{dependentId} {
        allow read:   if isOwner(userId) && isFullAccount();
        allow create: if isOwner(userId) && isFullAccount()
                   && request.resource.data.firstName is string
                   && request.resource.data.firstName.size() <= 100
                   && request.resource.data.lastName is string
                   && request.resource.data.lastName.size() <= 100;
        allow update: if isOwner(userId) && isFullAccount();
        allow delete: if isOwner(userId) && isFullAccount();
      }
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() &&
                     (isBookingPatient() || isBookingProvider() || isAdmin());
      allow create: if isFullAccount()
                 && request.resource.data.userId == request.auth.uid
                 && request.resource.data.status == 'pending'
                 && request.resource.data.patientName is string
                 && request.resource.data.patientName.size() <= 150
                 && request.resource.data.date is string
                 && request.resource.data.date.size() <= 20
                 && request.resource.data.time is string
                 && request.resource.data.time.size() <= 10;
      allow update: if isAdmin()
                 || isBookingProvider()
                 || (isBookingPatient()
                     && isFullAccount()
                     && request.resource.data.status == 'cancelled'
                     && request.resource.data.userId == resource.data.userId
                     && request.resource.data.providerId == resource.data.providerId
                     && request.resource.data.date == resource.data.date
                     && request.resource.data.time == resource.data.time);
      allow delete: if isAdmin();
    }

    match /availability/{providerId} {
      allow read: if isAuthenticated();
      match /slots/{date} {
        allow read: if isAuthenticated();
        allow write: if isFullAccount();
      }
    }

    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow create: if isFullAccount();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /insurance/{userId} {
      allow read:  if isOwner(userId);
      allow write: if isOwner(userId) && isFullAccount();
    }

    match /notifications/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /privacy/{userId} {
      allow read, write: if isOwner(userId);
    }

    match /paymentMethods/{docId} {
      allow read, delete: if isAuthenticated() &&
                             resource.data.userId == request.auth.uid;
      allow create: if isFullAccount();
    }

    match /supportRequests/{docId} {
      allow read: if isAuthenticated() &&
                     (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isFullAccount();
    }

    match /savedProviders/{userId} {
      allow read, write: if isOwner(userId) && isFullAccount();
    }

    match /providerUsers/{userId} {
      allow read:  if isOwner(userId) && isVerifiedProvider();
      allow write: if isOwner(userId) && isVerifiedProvider();
    }

    match /auditLog/{entryId} {
      allow create: if isFullAccount()
                 && request.resource.data.actorUid == request.auth.uid;
      allow read:   if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
