rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ================================================================
    // HELPER FUNCTIONS
    // ================================================================

    function isAuthenticated() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }
    function isFullAccount() {
      return isAuthenticated() &&
             request.auth.token.firebase.sign_in_provider != 'anonymous';
    }
    function isProviderOwner(providerId) {
      return isAuthenticated()
          && request.auth.token.provider == true
          && request.auth.token.providerId == providerId;
    }
    function isVerifiedProvider() {
      return isAuthenticated()
          && request.auth.token.provider == true
          && exists(/databases/$(database)/documents/providerUsers/$(request.auth.uid));
    }
    function isBookingPatient() {
      return isAuthenticated()
          && resource.data.userId == request.auth.uid;
    }
    function isBookingProvider() {
      return isAuthenticated()
          && request.auth.token.providerId == resource.data.providerId;
    }

    function validString(field, maxLen) {
      return field is string && field.size() > 0 && field.size() <= maxLen;
    }

    function validOptionalString(field, maxLen) {
      return !(field in request.resource.data) ||
             (request.resource.data[field] is string &&
              request.resource.data[field].size() <= maxLen);
    }

    function noScript(field) {
      return !(request.resource.data[field].matches('.*<script.*')) &&
             !(request.resource.data[field].matches('.*javascript:.*'));
    }

    // ================================================================
    // PROVIDERS
    // ================================================================
    match /providers/{providerId} {
      allow read: if true;
      allow write: if isAdmin() || isProviderOwner(providerId);
    }

    // ================================================================
    // USERS
    // ================================================================
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId);

      match /dependents/{dependentId} {
        allow read:   if isOwner(userId) && isFullAccount();
        allow create: if isOwner(userId) && isFullAccount()
                   && validString(request.resource.data.firstName, 100)
                   && validString(request.resource.data.lastName, 100)
                   && noScript('firstName')
                   && noScript('lastName');
        allow update: if isOwner(userId) && isFullAccount()
                   && validString(request.resource.data.firstName, 100)
                   && validString(request.resource.data.lastName, 100);
        allow delete: if isOwner(userId) && isFullAccount();
      }
    }

    // ================================================================
    // BOOKINGS
    // ================================================================
    match /bookings/{bookingId} {
      allow read: if isAuthenticated() &&
                     (isBookingPatient() || isBookingProvider() || isAdmin());

      allow create: if isFullAccount()
                 && request.resource.data.userId == request.auth.uid
                 && request.resource.data.status == 'pending'
                 && validString(request.resource.data.patientName, 150)
                 && validString(request.resource.data.date, 20)
                 && validString(request.resource.data.time, 10)
                 && validString(request.resource.data.providerId, 200)
                 && noScript('patientName')
                 && validOptionalString('notes', 1000)
                 && validOptionalString('reasonForVisit', 500);

      allow update: if isAdmin()
                 || isBookingProvider()
                 || (isBookingPatient()
                     && isFullAccount()
                     && request.resource.data.status == 'cancelled'
                     && request.resource.data.userId == resource.data.userId
                     && request.resource.data.providerId == resource.data.providerId
                     && request.resource.data.date == resource.data.date
                     && request.resource.data.time == resource.data.time);
      allow delete: if isAdmin();
    }

    // ================================================================
    // AVAILABILITY
    // ================================================================
    match /availability/{providerId} {
      allow read: if isAuthenticated();
      match /slots/{date} {
        allow read: if isAuthenticated();
        allow create, update: if isFullAccount() || isAdmin() || isProviderOwner(providerId);
        allow delete: if isAdmin() || isProviderOwner(providerId);
      }
    }

    // ================================================================
    // QUESTIONS
    // ================================================================
    match /questions/{questionId} {
      allow read: if isAuthenticated();
      allow create: if isFullAccount()
                 && request.resource.data.userId == request.auth.uid
                 && validString(request.resource.data.content, 2000)
                 && noScript('content');
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ================================================================
    // INSURANCE
    // ================================================================
    match /insurance/{userId} {
      allow read:  if isOwner(userId);
      allow write: if isOwner(userId) && isFullAccount();
    }

    // ================================================================
    // NOTIFICATIONS
    // ================================================================
    match /notifications/{userId} {
      allow read:  if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ================================================================
    // PRIVACY SETTINGS
    // ================================================================
    match /privacy/{userId} {
      allow read:  if isOwner(userId);
      allow write: if isOwner(userId);
    }

    // ================================================================
    // PAYMENT METHODS
    // ================================================================
    match /paymentMethods/{docId} {
      allow read, delete: if isAuthenticated() &&
                             resource.data.userId == request.auth.uid;
      allow create: if isFullAccount()
                 && request.resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    // ================================================================
    // SUPPORT REQUESTS
    // ================================================================
    match /supportRequests/{docId} {
      allow read: if isAuthenticated() &&
                     (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isFullAccount()
                 && request.resource.data.userId == request.auth.uid
                 && validString(request.resource.data.message, 5000)
                 && noScript('message');
      allow update: if isAdmin();
      allow delete: if false;
    }

    // ================================================================
    // SAVED PROVIDERS
    // ================================================================
    match /savedProviders/{userId} {
      allow read, write: if isOwner(userId) && isFullAccount();
    }

    // ================================================================
    // PROVIDER USERS (Dashboard accounts)
    // ================================================================
    match /providerUsers/{userId} {
      allow read:  if isOwner(userId) && request.auth.token.provider == true;
      allow write: if isOwner(userId) && isVerifiedProvider();
    }

    // ================================================================
    // AUDIT LOG
    // ================================================================
    match /auditLog/{entryId} {
      allow create: if isFullAccount()
                 && validOptionalString('action', 100)
                 && validOptionalString('targetId', 200);
      allow read:   if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ================================================================
    // ANALYTICS EVENTS
    // ================================================================
    match /analytics_events/{docId} {
      allow create: if isAuthenticated()
                 && validOptionalString('eventName', 100)
                 && validOptionalString('screen', 100);
      allow read:   if isAdmin();
      allow update: if false;
      allow delete: if false;
    }

    // ================================================================
    // PROVIDER APPLICATIONS
    // ================================================================
    match /providerApplications/{docId} {
      allow create: if validString(request.resource.data.name, 200)
                 && validString(request.resource.data.email, 200)
                 && noScript('name')
                 && noScript('email')
                 && validOptionalString('phone', 20)
                 && validOptionalString('specialty', 100)
                 && validOptionalString('message', 2000);
      allow read, update, delete: if isAdmin();
    }

    // ================================================================
    // INTAKE FORMS
    // ================================================================
    match /intakeForms/{docId} {
      allow read: if isAuthenticated() &&
                   (request.auth.uid == resource.data.userId || isAdmin());
      allow create, update: if isFullAccount()
                 && request.resource.data.userId == request.auth.uid
                 && validOptionalString('medications', 500)
                 && validOptionalString('allergies', 500)
                 && validOptionalString('conditions', 500)
                 && validOptionalString('surgeries', 500)
                 && validOptionalString('vaccinations', 500)
                 && validOptionalString('bloodType', 10)
                 && validOptionalString('height', 20)
                 && validOptionalString('weight', 20);
      allow delete: if false;
    }

    // ================================================================
    // PLATFORM COUNTERS
    // ================================================================
    match /platform/{docId} {
      allow read: if isAuthenticated();
      allow create: if isFullAccount()
                 && request.resource.data.totalSignups == 1;
      allow update: if isFullAccount()
                 && request.resource.data.totalSignups ==
                    resource.data.totalSignups + 1;
      allow delete: if false;
    }

    // ================================================================
    // VISIT SUMMARIES
    // ================================================================
    match /visitSummaries/{bookingId} {
      allow read: if isAuthenticated() &&
                   (isBookingPatient() || isBookingProvider() || isAdmin());
      allow create, update: if isVerifiedProvider() || isAdmin();
      allow delete: if false;
    }

    // ================================================================
    // WAITLIST
    // ================================================================
    match /waitlist/{docId} {
      allow create: if request.resource.data.email is string
                 && request.resource.data.email.size() > 0
                 && request.resource.data.email.size() <= 200
                 && request.resource.data.source is string;
      allow read, update, delete: if isAdmin();
    }

    // ================================================================
    // REP APPLICATIONS — public create, admin read/update only
    // Strict validation: locked status, no script injection,
    // rate limiting enforced client-side + field size caps
    // ================================================================
    match /repApplications/{docId} {
      allow create: if
        // Required fields present and valid
        validString(request.resource.data.name, 200)
        && validString(request.resource.data.email, 200)
        && noScript('name')
        && noScript('email')
        // Status must be 'new' on creation — cannot self-approve
        && request.resource.data.status == 'new'
        // Numeric fields must be zero on creation
        && request.resource.data.verifiedCount == 0
        && request.resource.data.pendingEarnings == 0
        // Optional field size caps
        && validOptionalString('phone', 20)
        && validOptionalString('city', 100)
        && validOptionalString('role', 100)
        && validOptionalString('hoursPerWeek', 50)
        && validOptionalString('paymentMethod', 50)
        && validOptionalString('paymentHandle', 100)
        && validOptionalString('heardFrom', 100)
        && validOptionalString('referredBy', 200)
        && validOptionalString('whyInterested', 1000)
        && validOptionalString('connections', 100)
        && validOptionalString('salesExp', 100)
        && validOptionalString('outreachMethods', 300)
        && validOptionalString('source', 100);

      // Only admin can read full application data
      allow read: if isAdmin();

      // Only admin can update (approve/reject, increment verifiedCount)
      allow update: if isAdmin();

      allow delete: if false;
    }

    // ================================================================
    // REP APP STATUS — minimal public status check (no sensitive data)
    // Written automatically when application is submitted.
    // Contains only: email, status, submittedAt — nothing sensitive.
    // ================================================================
    match /repAppStatus/{docId} {
      // Public create — written alongside repApplications on submit
      allow create: if
        validString(request.resource.data.email, 200)
        && request.resource.data.status == 'new'
        && noScript('email');

      // Public read — email + status only, no PII or payment data
      allow read: if true;

      // Only admin updates status (approved/rejected)
      allow update: if isAdmin();

      allow delete: if false;
    }

    // ================================================================
    // PROVIDER SUBMISSIONS — verified reps create, admin manages
    // Rep email is checked client-side against repApplications.
    // Server-side: enforce status, field caps, no script injection.
    // ================================================================
    match /providerSubmissions/{docId} {
      allow create: if
        // Required fields
        validString(request.resource.data.providerName, 200)
        && validString(request.resource.data.repEmail, 200)
        && noScript('providerName')
        && noScript('repEmail')
        // Status must be pending on creation — cannot self-approve
        && request.resource.data.status == 'pending_verification'
        // Commission fields must be false/null on creation
        && request.resource.data.commissionPaid == false
        // Optional field caps
        && validOptionalString('practiceName', 200)
        && validOptionalString('specialty', 100)
        && validOptionalString('city', 100)
        && validOptionalString('providerPhone', 20)
        && validOptionalString('providerEmail', 200)
        && validOptionalString('npi', 10)
        && validOptionalString('repName', 200)
        && validOptionalString('repPayment', 100)
        && validOptionalString('contactMethod', 100)
        && validOptionalString('interestLevel', 100)
        && validOptionalString('notes', 1000)
        && validOptionalString('telehealth', 50)
        && validOptionalString('acceptingNewPatients', 50)
        && validOptionalString('source', 100)
        && validOptionalString('claimedBy', 200);

      // Reps can read their own submissions for the status tracker
      allow read: if isAdmin()
        || (request.auth == null &&
            resource.data.repEmail is string);

      // Only admin can update status, commission, notes
      allow update: if isAdmin();

      allow delete: if false;
    }

    // ================================================================
    // CATCH-ALL — deny everything not explicitly allowed
    // ================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
