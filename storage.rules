rules_version = '2';

// ================================================================
// FIREBASE STORAGE RULES — Morava Care
// ================================================================
//
// facility-photos/{facilityId}/**
//   READ:  public (photos shown to patients in the app)
//   WRITE: only the facility manager who owns that facilityId
//          (verified via custom claim set by Admin SDK — cannot be self-edited)
//
// All other paths: deny
// ================================================================

service firebase.storage {
  match /b/{bucket}/o {

    // ── Facility photos ────────────────────────────────────────────────────
    match /facility-photos/{facilityId}/{allPaths=**} {
      // Public read — patients and case managers see facility photos
      allow read: if true;

      // Write only if:
      //   1. User is authenticated
      //   2. Their facilityId custom claim matches the folder they're writing to
      //      (stamped by Admin SDK in setRecoveryFacilityRole.js — tamper-proof)
      //   3. File is an image under 6 MB
      allow write: if request.auth != null
                   && request.auth.token.facilityId == facilityId
                   && request.resource.size < 6 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      // Only admin can delete facility photos (prevent operators wiping others' photos)
      allow delete: if request.auth != null
                    && request.auth.token.admin == true;
    }

    // ── Provider profile photos (existing) ────────────────────────────────
    match /provider-photos/{providerId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.providerId == providerId
                   && request.resource.size < 6 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
                    && (request.auth.token.providerId == providerId
                        || request.auth.token.admin == true);
    }

    // ── Deny everything else ──────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
