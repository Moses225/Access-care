rules_version = '2';

// ================================================================
// FIREBASE STORAGE RULES — Morava Care
// ================================================================
//
// facility-photos/{facilityId}/**
//   READ:  public (photos shown to patients in the app)
//   WRITE: only the facility manager who owns that facilityId
//          (verified via custom claim set by Admin SDK — cannot be self-edited)
//
// All other paths: deny
// ================================================================

service firebase.storage {
  match /b/{bucket}/o {

    // ── Facility photos & video tours ───────────────────────────────────────
    match /facility-photos/{facilityId}/{allPaths=**} {
      // Public read — patients and case managers see facility photos/videos
      allow read: if true;

      // Write only if authenticated, facilityId claim matches, and either an
      // image under 10 MB or a video tour under 200 MB.
      allow write: if request.auth != null
                   && request.auth.token.facilityId == facilityId
                   && (
                     (request.resource.contentType.matches('image/.*') && request.resource.size < 10 * 1024 * 1024)
                     || (request.resource.contentType.matches('video/.*') && request.resource.size < 200 * 1024 * 1024)
                   );

      // Operators can replace/delete their own media; admin can delete any
      allow delete: if request.auth != null
                    && (request.auth.token.facilityId == facilityId
                        || request.auth.token.admin == true);
    }

    // ── Provider profile photos (existing) ────────────────────────────────
    match /provider-photos/{providerId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.providerId == providerId
                   && request.resource.size < 6 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null
                    && (request.auth.token.providerId == providerId
                        || request.auth.token.admin == true);
    }

    // ── Deny everything else ──────────────────────────────────────────────
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
