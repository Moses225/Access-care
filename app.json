{
  "expo": {
    "name": "AccessCare",
    "slug": "accesscare",
    "version": "1.1.0",
    "scheme": "accesscare",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E75B6"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.accesscare.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "AccessCare needs your location to show nearby healthcare providers.",
        "NSCameraUsageDescription": "AccessCare needs access to your camera to take profile pictures.",
        "NSPhotoLibraryUsageDescription": "AccessCare needs access to your photos to set your profile picture."
      }
    },
    "android": {
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "package": "com.accesscare.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "YAIzaSyCYh1TzWIAonLgs32hW84fEQeatfDGlS54"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "AccessCare needs access to your photos to set your profile picture.",
          "cameraPermission": "AccessCare needs access to your camera to take profile pictures."
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "995509b6-4f68-418d-b6ea-de1591eae79c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/995509b6-4f68-418d-b6ea-de1591eae79c"
    }
  }
}
