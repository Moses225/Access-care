{
  "expo": {
    "name": "Morava",
    "slug": "morava",
    "version": "1.1.0",
    "scheme": "morava",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#00BCD4"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.moravacare.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Morava needs your location to show nearby healthcare providers.",
        "NSCameraUsageDescription": "Morava needs access to your camera to take profile pictures.",
        "NSPhotoLibraryUsageDescription": "Morava needs access to your photos to set your profile picture."
      }
    },
    "android": {
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png"
      },
      "package": "com.moravacare.app",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.INTERNET",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "EXPO_PUBLIC_GOOGLE_MAPS_API_KEY"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "Morava needs access to your photos to set your profile picture.",
          "cameraPermission": "Morava needs access to your camera to take profile pictures."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#14B8A6",
          "sounds": []
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "morava",
          "project": "react-native"
        }
      ]
    ],
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "995509b6-4f68-418d-b6ea-de1591eae79c"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/995509b6-4f68-418d-b6ea-de1591eae79c"
    }
  }
}
