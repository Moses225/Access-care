# Morava — example environment file
# Copy to `.env` and fill in your own values. NEVER commit a real .env.
# All client-side config is provided via EXPO_PUBLIC_* variables.

# ── Firebase (client config) ──────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# ── Google Maps ───────────────────────────────────────────────────────────
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_STATIC_KEY=

# ── App Check (development only) ──────────────────────────────────────────
# Local debug token used by the App Check CustomProvider in dev.
EXPO_PUBLIC_APP_CHECK_DEBUG_TOKEN=

# ── Server-side secrets ───────────────────────────────────────────────────
# Cloud Functions secrets (Stripe, Resend, Twilio) are NOT set here.
# They are managed via Firebase Functions secrets / EAS environment, never in source.
# Operational scripts authenticate via GOOGLE_APPLICATION_CREDENTIALS (a path to a
# service account key kept OUTSIDE version control).
